# ================================================================
# B.CAVE Competitor Radar - Environment Variables
#
# Copy this file to .env and fill in the values.
# NEVER commit .env to git.
# ================================================================

# ----------------------------------------------------------------
# Supabase
# ----------------------------------------------------------------
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=eyJhbGc...
SUPABASE_SERVICE_KEY=eyJhbGc...        # 워커 전용 (RLS bypass). 절대 노출 금지.
SUPABASE_DB_URL=postgresql://postgres:...@db.xxx.supabase.co:5432/postgres

# ----------------------------------------------------------------
# Snowflake (자사 DW)
# ----------------------------------------------------------------
SNOWFLAKE_ACCOUNT=cl49554.ap-northeast-2.aws
SNOWFLAKE_USER=SVC_COMPETITOR_RADAR_READER
SNOWFLAKE_PASSWORD=                     # 또는 key-pair 인증 사용 시 SNOWFLAKE_PRIVATE_KEY_PATH
SNOWFLAKE_WAREHOUSE=COMPUTE_WH
SNOWFLAKE_DATABASE=BCAVE
SNOWFLAKE_SCHEMA=SEWON
SNOWFLAKE_ROLE=READER_ROLE

# ----------------------------------------------------------------
# Ollama (로컬 LLM)
# ----------------------------------------------------------------
OLLAMA_HOST=http://ollama:11434
OLLAMA_LLM_MODEL=gemma4:e4b
OLLAMA_EMBED_MODEL=embeddinggemma:300m

# ----------------------------------------------------------------
# Slack
# ----------------------------------------------------------------
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...
SLACK_OPS_WEBHOOK_URL=https://hooks.slack.com/services/...     # 에러 알림용 별도 채널
SLACK_REPORT_CHANNEL=#competitor-radar

# ----------------------------------------------------------------
# Notion
# ----------------------------------------------------------------
NOTION_TOKEN=secret_xxxxxxxxxxxx
NOTION_PARENT_PAGE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxx     # "B.CAVE Competitor Radar" 페이지 ID

# ----------------------------------------------------------------
# n8n
# ----------------------------------------------------------------
N8N_USER=admin
N8N_PASSWORD=                            # 강한 비밀번호로 설정
N8N_HOST=radar-n8n.bcave.internal       # 사내 도메인
N8N_WEBHOOK_URL=http://radar-n8n.bcave.internal/

# ----------------------------------------------------------------
# Viewer (Vercel용. Vercel 대시보드에 별도 등록도 필요)
# ----------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGc...
NEXT_PUBLIC_DASHBOARD_URL=https://radar.bcave.co.kr

# ----------------------------------------------------------------
# 기타
# ----------------------------------------------------------------
LOG_LEVEL=INFO
SCRAPE_MIN_DELAY_SEC=3.0                 # 거버넌스: 최소 3초 (낮추지 말 것)
SCRAPE_USER_AGENT=B.CAVE-Competitor-Radar/1.0 (internal analytics)
