# viewer/.env.example
# 복사: cp .env.example .env.local
# .env.local 은 절대 커밋 금지 (.gitignore에 포함됨)

# ── Supabase — 클라이언트용 (anon) ──────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGc...

# ── Supabase — 서버 사이드 admin 키 (service_role) ──────────
# Server Component · Server Action 에서 supabaseAdmin() 가 사용.
# 사용자 관리, 브랜드 플래그 변경 등 RLS bypass 가 필요한 서버 전용 작업에 필요.
# 절대 NEXT_PUBLIC_ 접두사 붙이지 말 것 — 클라이언트 번들에 포함되면 안 됨.
# import "server-only" 가 클라이언트 번들 유입을 차단하지만 키 자체는 서버에서만 읽혀야 함.
# Vercel 배포 시: Project Settings → Environment Variables → SUPABASE_SERVICE_KEY 추가.
# 이 파일을 .env.local 에 복사 후 실제 키로 교체. .env.local 은 git 에 절대 commit 금지.
SUPABASE_SERVICE_KEY=eyJhbGc...

# ── Mock 모드 ───────────────────────────────────────────────
# true(기본): lib/mock-data.ts 의 더미 데이터로 화면 렌더 — Supabase 불필요
# false: lib/queries.ts 가 실제 Supabase 쿼리 실행
NEXT_PUBLIC_USE_MOCK=true

# ── 대시보드 URL (Slack/Notion 링크용, 워커가 사용) ────────
NEXT_PUBLIC_DASHBOARD_URL=https://radar.bcave.co.kr
