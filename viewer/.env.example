# viewer/.env.example
# 복사: cp .env.example .env.local
# .env.local 은 절대 커밋 금지 (.gitignore에 포함됨)

# ── Supabase ────────────────────────────────────────────────
# 뷰어는 anon 키만 사용한다. service_role 키는 워커 전용 — 절대 여기 넣지 말 것.
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGc...

# ── Mock 모드 ───────────────────────────────────────────────
# true(기본): lib/mock-data.ts 의 더미 데이터로 화면 렌더 — Supabase 불필요
# false: lib/queries.ts 가 실제 Supabase 쿼리 실행
NEXT_PUBLIC_USE_MOCK=true

# ── 대시보드 URL (Slack/Notion 링크용, 워커가 사용) ────────
NEXT_PUBLIC_DASHBOARD_URL=https://radar.bcave.co.kr
